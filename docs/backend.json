
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the DailyPulse application, storing core user information, role, and onboarding status.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's unique email address.",
          "format": "email"
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's profile avatar image.",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "enum": ["patient", "doctor"],
          "description": "The role of the user."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        },
        "onboardingCompleted": {
          "type": "boolean",
          "description": "A flag indicating whether the user has completed onboarding."
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "avatarUrl",
        "role",
        "createdAt",
        "onboardingCompleted"
      ]
    },
    "DoctorProfile": {
      "title": "DoctorProfile",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "specialization": { "type": "string" },
        "bio": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "Assignment": {
      "title": "Assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DoctorNote": {
      "title": "DoctorNote",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles with roles."
        }
      },
      {
        "path": "/doctorProfiles/{userId}",
        "definition": {
          "entityName": "DoctorProfile",
          "schema": { "$ref": "#/backend/entities/DoctorProfile" },
          "description": "Extended info for doctors."
        }
      },
      {
        "path": "/assignments/{assignmentId}",
        "definition": {
          "entityName": "Assignment",
          "schema": { "$ref": "#/backend/entities/Assignment" },
          "description": "Patient-Doctor relationship requests."
        }
      },
      {
        "path": "/doctorNotes/{noteId}",
        "definition": {
          "entityName": "DoctorNote",
          "schema": { "$ref": "#/backend/entities/DoctorNote" },
          "description": "Clinical notes from doctors to patients."
        }
      }
    ]
  }
}
