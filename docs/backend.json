
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Core user profile with role-based attributes.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["patient", "doctor"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "onboardingCompleted": { "type": "boolean" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "DoctorProfile": {
      "title": "DoctorProfile",
      "type": "object",
      "description": "Public profile information for medical professionals.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "bio": { "type": "string" },
        "isVerified": { "type": "boolean" }
      }
    },
    "Assignment": {
      "title": "Assignment",
      "type": "object",
      "description": "A link between a patient and a doctor.",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DoctorNote": {
      "title": "DoctorNote",
      "type": "object",
      "description": "Private clinical notes for patients.",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/doctorProfiles/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/DoctorProfile" },
          "description": "Extended doctor info."
        }
      },
      {
        "path": "/assignments/{assignmentId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Assignment" },
          "description": "Consultation links."
        }
      },
      {
        "path": "/doctorNotes/{noteId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/DoctorNote" },
          "description": "Clinical messages."
        }
      }
    ]
  }
}
