
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the DailyPulse application.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor"] },
        "onboardingCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "DoctorProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DoctorProfile",
      "type": "object",
      "description": "Extended profile for users with the doctor role.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "bio": { "type": "string" },
        "isVerified": { "type": "boolean" }
      },
      "required": ["userId", "name"]
    },
    "Assignment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Assignment",
      "type": "object",
      "description": "Relationship between a patient and a doctor.",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "status"]
    },
    "DoctorNote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DoctorNote",
      "type": "object",
      "description": "Clinical notes written by a doctor for a patient.",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "content"]
    },
    "UserMoodEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserMoodEntry",
      "type": "object",
      "description": "Records a user's daily mood check-in.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "mood": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "message": { "type": "string" },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mood", "date", "createdAt"]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Social community post.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatarUrl": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "createdAt"]
    },
    "Like": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Like",
      "type": "object",
      "description": "A like on a social post.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "postId"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profile data."
        }
      },
      {
        "path": "/doctorProfiles/{profileId}",
        "definition": {
          "entityName": "DoctorProfile",
          "schema": { "$ref": "#/backend/entities/DoctorProfile" },
          "description": "Public doctor profile data."
        }
      },
      {
        "path": "/assignments/{assignmentId}",
        "definition": {
          "entityName": "Assignment",
          "schema": { "$ref": "#/backend/entities/Assignment" },
          "description": "Patient-doctor consultation requests."
        }
      },
      {
        "path": "/doctorNotes/{noteId}",
        "definition": {
          "entityName": "DoctorNote",
          "schema": { "$ref": "#/backend/entities/DoctorNote" },
          "description": "Private clinical notes."
        }
      },
      {
        "path": "/users/{userId}/moodEntries/{entryId}",
        "definition": {
          "entityName": "UserMoodEntry",
          "schema": { "$ref": "#/backend/entities/UserMoodEntry" },
          "description": "User daily mood entries."
        }
      },
      {
        "path": "/posts/{postId}",
        "definition": {
          "entityName": "Post",
          "schema": { "$ref": "#/backend/entities/Post" },
          "description": "Public community posts."
        }
      },
      {
        "path": "/posts/{postId}/likes/{userId}",
        "definition": {
          "entityName": "Like",
          "schema": { "$ref": "#/backend/entities/Like" },
          "description": "Likes on posts."
        }
      }
    ]
  }
}
