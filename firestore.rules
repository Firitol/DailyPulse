
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if user matches UID
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- TEMPORARY: Open access for development phase ---
    // In production, these should be restricted to owners/assigned doctors.
    match /{document=**} {
      allow read, write: if true;
    }

    /* 
    // Example of production rules (disabled for development)
    match /users/{userId} {
      allow read, write: if isUser(userId);
    }
    match /doctorProfiles/{profileId} {
      allow read: if isSignedIn();
      allow write: if isUser(profileId);
    }
    match /assignments/{id} {
      allow read, write: if isSignedIn();
    }
    match /doctorNotes/{id} {
      allow read, write: if isSignedIn(); 
    }
    match /posts/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /posts/{id}/likes/{uid} {
      allow read, write: if isSignedIn();
    }
    */
  }
}
