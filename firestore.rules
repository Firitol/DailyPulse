
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * Permissive rules for development.
     * This allows any authenticated or unauthenticated user to read and write to any document.
     * Deployment timestamp: 2024-05-22T12:00:00Z (Triggering fresh deployment)
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
